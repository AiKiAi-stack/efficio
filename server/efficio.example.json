{
  "$schema": "https://example.com/efficio-config-schema.json",
  "server": {
    "port": 3001,
    "host": "0.0.0.0",
    "env": "production",
    "logLevel": "info",
    "allowedOrigins": [
      "http://localhost:5173",
      "http://localhost:5174",
      "http://localhost:5175"
    ]
  },
  "database": {
    "mode": "sqlite",
    "sqlitePath": "./data/efficiency.db"
  },
  "ai": {
    "provider": "anthropic",
    "providers": {
      "anthropic": {
        "apiKey": "sk-ant-...",
        "endpoint": "https://api.anthropic.com",
        "model": "claude-sonnet-4-6"
      },
      "openai": {
        "apiKey": "sk-...",
        "endpoint": "https://api.openai.com/v1",
        "model": "gpt-4o"
      },
      "deepseek": {
        "apiKey": "sk-...",
        "endpoint": "https://api.deepseek.com/v1",
        "model": "deepseek-chat"
      }
    }
  },
  "cron": {
    "enabled": true,
    "weeklySummary": "0 8 * * 1"
  }
}
