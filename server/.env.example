# Server Configuration
PORT=3001
NODE_ENV=development

# Supabase Configuration
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# CORS Origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# =====================================
# AI Provider Configuration
# =====================================
# Choose ONE provider by setting the corresponding API key
# Then set AI_PROVIDER to the provider name
# =====================================

# AI Provider Selection (anthropic | openai | deepseek | zhipu | kimi | nvidia | vllm | aliyun | volcengine | minimax)
AI_PROVIDER=anthropic

# Anthropic API (Claude) - https://docs.anthropic.com/claude/reference/getting-started-with-the-api
ANTHROPIC_API_KEY=your_anthropic_api_key

# OpenAI API (GPT-4) - https://platform.openai.com/docs/quickstart
OPENAI_API_KEY=your_openai_api_key

# DeepSeek API - https://platform.deepseek.com/api-docs/
DEEPSEEK_API_KEY=your_deepseek_api_key

# Zhipu AI (GLM) - https://open.bigmodel.cn/dev/api
ZHIPU_API_KEY=your_zhipu_api_key

# Kimi (Moonshot AI) - https://platform.moonshot.cn/docs/
KIMI_API_KEY=your_kimi_api_key

# NVIDIA NIM - https://docs.api.nvidia.com/nim/
NVIDIA_API_KEY=your_nvidia_api_key

# vLLM (Self-hosted) - https://docs.vllm.ai/en/stable/
VLLM_API_KEY=vllm  # Optional, vLLM doesn't require API key by default
VLLM_ENDPOINT=http://localhost:8000/v1
VLLM_MODEL=default

# Alibaba Cloud DashScope (Qwen) - https://help.aliyun.com/zh/dashscope/
ALIYUN_API_KEY=your_aliyun_api_key

# Volcengine (Doubao/Ark) - https://www.volcengine.com/docs/82379
VOLCENGINE_API_KEY=your_volcengine_api_key

# MiniMax - https://platform.minimaxi.com/document/guides
MINIMAX_API_KEY=your_minimax_api_key
